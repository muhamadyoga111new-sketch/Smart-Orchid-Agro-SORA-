<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ITPROJEK" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Anti-ghosting: solid window background prevents see-through -->
        <item name="android:windowBackground">@color/bg_app</item>
        <item name="android:windowIsTranslucent">false</item>

        <!-- Transparent status/nav bar for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.ITPROJEK" parent="Base.Theme.ITPROJEK" />
</resources>